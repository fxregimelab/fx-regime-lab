# Copy to `.env.local` in this directory (`web/.env.local`).
# Next.js loads it for `next dev`, `next build`, and `npm run pages:build`.
#
# CRITICAL — browser bundle:
# NEXT_PUBLIC_* names are inlined at compile time into client JavaScript.
# They must be present when you run the Cloudflare Pages build (next-on-pages),
# either here locally or in Cloudflare Pages → Settings → Environment variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
