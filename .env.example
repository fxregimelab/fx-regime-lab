# Copy to `.env` and replace every placeholder with real values.
# Never commit `.env` (gitignored).

# Required for pipeline (FRED yields / macro series)
FRED_API_KEY=your_fred_api_key_here

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional backup data providers (empty = disabled)
# TWELVE_DATA_KEY=
# POLYGON_KEY=

# Optional
# NOTION_TOKEN=

# --- Next.js app (`web/`) — browser bundle
# Copy `web/.env.local.example` to `web/.env.local` and set:
# NEXT_PUBLIC_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY
# See DEPLOY.md (build-time env for Cloudflare Pages).
