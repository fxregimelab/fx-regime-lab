# Copy to `.env` and replace every placeholder with real values.
# Never commit `.env` (gitignored).

# ── Pipeline ───────────────────────────────────────────────────────────────────

# FRED API (free) — used for US 2Y yields and macro release calendar
# Register at: https://fred.stlouisfed.org → My Account → API Keys
FRED_API_KEY=your_fred_api_key_here

# Supabase — Project Settings → API in your dashboard
# Project ref is the 20-char ID in your project URL: https://<ref>.supabase.co
SUPABASE_PROJECT_REF=your_20_char_project_ref
SUPABASE_URL=https://your_20_char_project_ref.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenRouter (free AI models — pipeline AI briefs only)
# Register at: https://openrouter.ai → Keys  (free, no credit card needed)
# Models are hardcoded in pipeline/src/ai/client.py:
#   Primary:  minimax/minimax-m1:free
#   Fallback: meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Next.js web app (web/) ─────────────────────────────────────────────────────
# These are read at build time and exposed to the browser (NEXT_PUBLIC_ prefix).
# Create web/.env.local with these two values (copy from Supabase dashboard above).
NEXT_PUBLIC_SUPABASE_URL=https://your_20_char_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
NEXT_JS_URL=https://your-deployed-site.com

# POST /api/revalidate — send header x-revalidate-secret with this value (server-only, not NEXT_PUBLIC)
REVALIDATE_SECRET=your_random_secret_here

# ── Optional / future ──────────────────────────────────────────────────────────
# TWELVE_DATA_KEY=     # backup FX data (not used yet)
# POLYGON_KEY=         # backup FX data (not used yet)
