{
  "chat": {
    "defaultModel": "claude-sonnet-4-5",
    "alwaysReadFiles": ["TASK.md"],
    "contextStrategy": "focused"
  },
  "indexing": {
    "respectGitignore": true,
    "maxFileSize": 500000
  },
  "editor": {
    "formatOnSave": true,
    "defaultFormatter": "prettier"
  },
  "plugins": {
    "cloudflare": {
      "enabled": true
    },
    "context7-plugin": {
      "enabled": true
    },
    "vercel": {
      "enabled": true
    }
  }
}
